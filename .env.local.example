# ─── MongoDB ──────────────────────────────────────────────────────────────────
# Get a free cluster at https://cloud.mongodb.com
MONGODB_URI=

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET=secret

# Google OAuth — create at https://console.cloud.google.com
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# ─── Gmail SMTP ───────────────────────────────────────────────────────────────
# Use an App Password (requires 2FA): https://myaccount.google.com/apppasswords
GMAIL_USER=
GMAIL_APP_PASSWORD=

# ─── Cron ─────────────────────────────────────────────────────────────────────
# Vercel auto-generates CRON_SECRET and injects it into cron requests.
# You do NOT need to set this manually on Vercel.
# Only set it locally if you want to test /api/cron manually.
CRON_SECRET=